@inject Portal.Web.Configuration.SecurityProfile SecurityProfile
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Acme Employee Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

@{
    var isVulnerable = SecurityProfile.IsVulnerable;
}

<div class="profile-banner @(isVulnerable ? "banner-vulnerable" : "banner-secure") text-center py-1 small fw-semibold">
    @if (isVulnerable)
    {
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        <text>VULNERABLE MODE — For authorised training and assessment only. Do not deploy publicly.</text>
    }
    else
    {
        <i class="bi bi-shield-check-fill me-1"></i>
        <text>SECURE MODE — Security controls are active.</text>
    }
</div>

<nav class="navbar navbar-dark bg-dark px-3">
    <a class="navbar-brand fw-bold" href="/">
        <i class="bi bi-building me-1"></i>Acme Employee Portal
    </a>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="d-flex align-items-center gap-3">
            <span class="text-light small">
                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                @if (User.IsInRole("Admin"))
                {
                    <span class="badge bg-danger ms-1">Admin</span>
                }
            </span>
            <form method="post" action="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-light">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </div>
    }
</nav>

<div class="container-fluid">
    <div class="row">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <nav class="col-md-2 sidebar d-flex flex-column py-3 pe-0">
                <ul class="nav nav-pills flex-column gap-1">
                    <li class="nav-item">
                        <a class="nav-link sidebar-link" href="/"><i class="bi bi-house me-2"></i>Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link" href="/Employees"><i class="bi bi-people me-2"></i>Employee Directory</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link" href="/Announcements"><i class="bi bi-megaphone me-2"></i>Announcements</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link" href="/Expenses"><i class="bi bi-receipt me-2"></i>My Expenses</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link" href="/Profile"><i class="bi bi-person me-2"></i>My Profile</a>
                    </li>
                    @if (isVulnerable || User.IsInRole("Admin"))
                    {
                        <li class="nav-item mt-2">
                            <a class="nav-link sidebar-link admin-link" href="/Admin">
                                <i class="bi bi-gear me-2"></i>Admin Panel
                                @if (isVulnerable)
                                {
                                    <span class="badge bg-danger ms-1" title="Unauthenticated access in Vulnerable mode">!</span>
                                }
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        }

        <main class="@(User.Identity?.IsAuthenticated == true ? "col-md-10" : "col-12") py-4 px-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
